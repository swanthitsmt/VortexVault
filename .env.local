APP_ENV=local
EDGE_BIND_PORT=8000
FLOWER_BIND_PORT=5555
MINIO_CONSOLE_PORT=9001

POSTGRES_USER=fluxdb
POSTGRES_PASSWORD=fluxdb
POSTGRES_DB=fluxdb

PG_SHARED_BUFFERS=2GB
PG_EFFECTIVE_CACHE_SIZE=6GB
PG_MAINTENANCE_WORK_MEM=512MB
PG_WORK_MEM=32MB
PG_MAX_WAL_SIZE=12GB
PG_CHECKPOINT_TIMEOUT=15min

MINIO_ROOT_USER=fluxdb
MINIO_ROOT_PASSWORD=fluxdb123
MINIO_BUCKET_RAW=raw-combos
MINIO_BUCKET_EXPORT=exports

MEILI_MASTER_KEY=fluxdb-master-key

INGEST_WORKER_CONCURRENCY=2
MERGE_WORKER_CONCURRENCY=1
EXPORT_WORKER_CONCURRENCY=1

INGEST_STREAM_CHUNK_BYTES=4194304
INGEST_BATCH_DOCS=20000
INGEST_CHECKPOINT_STRIDE_GB=10

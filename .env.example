APP_NAME="FluxDB Search"
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
SECRET_KEY=change-me

BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=admin123

# Docker-focused DB settings (edit these three only for Docker mode)
POSTGRES_USER=combo
POSTGRES_PASSWORD=combo
POSTGRES_DB=combo_db
# URL-encoded DB password used for app connection string in Docker.
# If password includes reserved characters (e.g. @ : / ? #), encode it here.
# Example: POSTGRES_PASSWORD=demo_pass@123 -> POSTGRES_PASSWORD_URLENC=demo_pass%40123
POSTGRES_PASSWORD_URLENC=combo
# Docker bind paths
# DATA_BIND_PATH examples:
#   macOS: /Users/<you>/FluxDB/data
#   Linux: /home/<you>/fluxdb/data
#   Windows: D:/FluxDB/data
DATA_BIND_PATH=./data
# PGDATA_BIND_PATH can be named volume (`pgdata`) or host path.
# Windows D drive example: D:/FluxDB/postgresql_db
PGDATA_BIND_PATH=pgdata
# Docker-only internal working directory for large job state/checkpoints.
# Keep this on container volume for better IO stability.
JOB_WORKDIR_DOCKER=/var/lib/fluxdb/jobs

# For native (non-Docker) mode, point DATABASE_URL to localhost DB.
# In Docker mode, docker-compose auto-builds DATABASE_URL from POSTGRES_* above.
DATABASE_URL=postgresql+asyncpg://combo:combo@localhost:5432/combo_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Native-mode job working directory
JOB_WORKDIR=./data/jobs
CLEANER_FLUSH_EVERY=5000
UPLOAD_BATCH_SIZE=100000
UPLOAD_COMMIT_EVERY_BATCHES=8
UPLOAD_SHARD_COUNT=8
UPLOAD_MANIFEST_ENABLED=true
# Enable chunked upload only when file size is at least this value (MB)
UPLOAD_MANIFEST_MIN_FILE_MB=64
# Target chunk size for line-safe byte-range chunking (MB)
UPLOAD_CHUNK_TARGET_MB=128
# Number of parallel upload chunk workers
UPLOAD_MANIFEST_PARALLEL_WORKERS=6
UPLOAD_AUTO_TUNE_WORKERS=true
# If PG active sessions are above this, upload auto-tuner reduces parallel chunk workers
UPLOAD_AUTO_TUNE_MAX_PG_ACTIVE=64
# on|off|local|remote_write|remote_apply
UPLOAD_SYNCHRONOUS_COMMIT=off
MERGE_BATCH_SIZE=250000
MERGE_COMMIT_EVERY_BATCHES=4
MERGE_DROP_STAGING_ON_SUCCESS=true
# Drop and rebuild GIN trigram indexes during merge for massive speedup (true|false).
# Keep false for safer production behavior unless you are in a controlled maintenance window.
MERGE_DROP_INDEXES=false
MERGE_ADVISORY_LOCK_KEY=424242
STAGING_CLEANUP_ENABLED=true
STAGING_RETENTION_HOURS=12
PIPELINE_CLEANUP_OUTPUT_ON_SUCCESS=true
PIPELINE_CLEANUP_JOB_WORKDIR_ON_SUCCESS=true
PIPELINE_CLEANUP_CHECKPOINTS_ON_SUCCESS=true
# PostgreSQL memory settings for merge session (index rebuild and sort/hash)
MERGE_MAINTENANCE_WORK_MEM=1GB
MERGE_WORK_MEM=256MB
MAX_EXPORT_ROWS=5000000
SEARCH_STATEMENT_TIMEOUT_MS=2500
SEARCH_COUNT_TIMEOUT_MS=12000
DASHBOARD_STATUS_CACHE_SECONDS=10
REGEX_MIN_CHARS=3

# Elasticsearch
ES_ENABLED=true
ES_URL=http://elasticsearch:9200
ES_NUMBER_OF_SHARDS=3
ES_NUMBER_OF_REPLICAS=1
ES_TIMEOUT=30
ES_SYNC_BATCH_SIZE=5000
ES_MIN_SYNC_RATIO=0.9
ES_SYNC_CHECK_INTERVAL_SECONDS=30

# Worker
WORKER_CONCURRENCY=2
WORKER_CLEAN_CONCURRENCY=2
WORKER_UPLOAD_CONCURRENCY=2
WORKER_MERGE_CONCURRENCY=1
WORKER_PIPELINE_CONCURRENCY=1

# PostgreSQL runtime tuning (Docker DB container)
PG_SHARED_BUFFERS=1GB
PG_EFFECTIVE_CACHE_SIZE=3GB
PG_MAINTENANCE_WORK_MEM=512MB
PG_WORK_MEM=16MB
PG_WAL_COMPRESSION=on
PG_MAX_WAL_SIZE=12GB
PG_CHECKPOINT_TIMEOUT=15min
PG_CHECKPOINT_COMPLETION_TARGET=0.9
PG_RANDOM_PAGE_COST=1.1
PG_EFFECTIVE_IO_CONCURRENCY=200
